<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.IPOTech" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorPrimaryVariant">@color/primary_dark_teal</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">@color/accent_green</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark_teal</item>
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <!-- Industrial menu item shape -->
    <style name="ShapeAppearance.IPOTech.MenuItemShape" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>

    <!-- Industrial menu text appearance -->
    <style name="TextAppearance.IPOTech.MenuItem" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Industrial Alert Dialog Style -->
    <style name="IndustrialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/IndustrialAlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/IndustrialAlertDialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/IndustrialAlertDialog.PositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/IndustrialAlertDialog.NegativeButton</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.IPOTech.Dialog</item>
    </style>

    <style name="ShapeAppearance.IPOTech.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="IndustrialAlertDialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/exit_red</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="IndustrialAlertDialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="IndustrialAlertDialog.PositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/exit_red</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="IndustrialAlertDialog.NegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary_teal</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <!-- Industrial squared shapes -->
    <style name="ShapeAppearance.IPOTech.LeftRounded" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">6dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.IPOTech.RightRounded" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">6dp</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <!-- Industrial toggle button styles -->
    <style name="Widget.IPOTech.Button.Toggle.On" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/selector_toggle_on</item>
        <item name="android:textColor">@color/selector_toggle_on_text</item>
        <item name="strokeColor">@color/industrial_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.IPOTech.LeftRounded</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Widget.IPOTech.Button.Toggle.Off" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/selector_toggle_off</item>
        <item name="android:textColor">@color/selector_toggle_off_text</item>
        <item name="strokeColor">@color/industrial_stroke</item>
        <item name="strokeWidth">2dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.IPOTech.RightRounded</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
</resources>