<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow/shadow ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33000000" />
        </shape>
    </item>
    <!-- Main LED body -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/led_off" />
            <stroke android:width="1dp" android:color="#1E2A2A" />
        </shape>
    </item>
    <!-- Inner highlight for 3D effect -->
    <item android:left="4dp" android:top="3dp" android:right="6dp" android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#20FFFFFF" />
        </shape>
    </item>
</layer-list>
