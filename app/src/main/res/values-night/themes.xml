<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.IPOTech" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorPrimaryVariant">@color/primary_dark_teal</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">@color/accent_green</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark_teal</item>
        <!-- Customize your theme here. -->
    </style>

    <!-- Industrial Alert Dialog Style (Dark) -->
    <style name="IndustrialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorSurface">#1E2A2A</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="materialAlertDialogTitleTextStyle">@style/IndustrialAlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/IndustrialAlertDialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/IndustrialAlertDialog.PositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/IndustrialAlertDialog.NegativeButton</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.IPOTech.Dialog</item>
    </style>

    <style name="ShapeAppearance.IPOTech.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="IndustrialAlertDialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/exit_red</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="IndustrialAlertDialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">#8B9A9E</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="IndustrialAlertDialog.PositiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/exit_red</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="IndustrialAlertDialog.NegativeButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary_teal</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>
</resources>